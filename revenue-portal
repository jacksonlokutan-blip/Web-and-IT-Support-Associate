<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>County Digital Revenue & Payment Portal</title>
    <style>
        /* CSS RESET & BRAND COLOR VARIABLES */
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', system-ui, sans-serif; }
        :root { --navy: #001219; --teal: #0a9396; --gold: #ee9b00; --light-bg: #f8fafc; --border: #e2e8f0; }

        body { background-color: var(--light-bg); color: var(--navy); padding: 20px; }

        /* DASHBOARD GRID LAYOUT */
        .dashboard-container { max-width: 1400px; margin: 0 auto; display: grid; grid-template-columns: 260px 1fr; gap: 30px; }

        /* SIDEBAR NAVIGATION */
        aside { background-color: white; border: 1px solid var(--border); border-radius: 12px; padding: 30px 20px; height: fit-content; }
        .gov-brand { font-size: 18px; font-weight: 800; letter-spacing: 0.5px; color: var(--navy); margin-bottom: 40px; border-bottom: 2px solid var(--light-bg); padding-bottom: 15px; }
        .gov-brand span { color: var(--teal); }
        .nav-links { list-style: none; }
        .nav-links li { margin-bottom: 15px; }
        .nav-links a { text-decoration: none; color: #64748b; font-weight: 600; display: block; padding: 10px 15px; border-radius: 6px; transition: all 0.2s; }
        .nav-links a.active, .nav-links a:hover { background-color: var(--light-bg); color: var(--teal); }

        /* MAIN CONTENT SECTION */
        main { display: flex; flex-direction: column; gap: 30px; }
        .header-bar { display: flex; justify-content: space-between; align-items: center; background: white; padding: 20px 30px; border: 1px solid var(--border); border-radius: 12px; }
        .header-bar h1 { font-size: 24px; font-weight: 700; }
        .secure-badge { background: #e0f2fe; color: #0369a1; padding: 6px 12px; border-radius: 50px; font-size: 12px; font-weight: 700; text-transform: uppercase; }

        /* TWO COLUMN PAYMENT LAYOUT */
        .revenue-layout { display: flex; flex-wrap: wrap; gap: 25px; }
        .form-card { background: white; border: 1px solid var(--border); border-radius: 12px; padding: 30px; flex: 1 1 550px; }
        .summary-card { background: white; border: 1px solid var(--border); border-radius: 12px; padding: 30px; flex: 1 1 350px; height: fit-content; }

        /* FORM DESIGN ELEMENTS */
        .form-group { margin-bottom: 20px; }
        label { display: block; font-weight: 600; margin-bottom: 8px; font-size: 14px; color: #475569; }
        input, select { width: 100%; padding: 12px; border: 1px solid var(--border); border-radius: 6px; font-size: 15px; background-color: var(--light-bg); transition: border 0.3s; }
        input:focus, select:focus { outline: none; border-color: var(--teal); background-color: white; }
        
        .payment-methods { display: flex; gap: 15px; margin-top: 10px; }
        .method-option { border: 1px solid var(--border); padding: 15px; border-radius: 8px; flex: 1; text-align: center; font-weight: 700; font-size: 14px; cursor: pointer; background: var(--light-bg); }
        .method-option.selected { border-color: var(--teal); background: #f0fdfa; color: var(--teal); }

        /* BUTTONS */
        .pay-btn { width: 100%; background-color: var(--gold); color: var(--navy); border: none; padding: 14px; font-size: 16px; font-weight: 700; border-radius: 6px; cursor: pointer; transition: background 0.3s; margin-top: 10px; }
        .pay-btn:hover { background-color: #ca8100; }

        /* BILLING SUMMARY ROW */
        .summary-row { display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 15px; }
        .total-row { border-top: 2px dashed var(--border); margin-top: 15px; padding-top: 15px; font-weight: 700; font-size: 18px; }

        @media (max-width: 992px) {
            .dashboard-container { grid-template-columns: 1fr; }
            aside { display: none; }
        }
    </style>
</head>
<body>

    <div class="dashboard-container">
        <aside>
            <div class="gov-brand">COUNTY<span>PORTAL</span></div>
            <ul class="nav-links">
                <li><a href="index.html">Tourism Hub</a></li>
                <li><a href="dashboard.html">Agribusiness Data</a></li>
                <li><a href="#" class="active">Revenue Portals</a></li>
                <li><a href="#">County Projects</a></li>
            </ul>
        </aside>

        <main>
            <div class="header-bar">
                <div>
                    <h1>Unified Revenue e-Services</h1>
                    <p style="color: #64748b; font-size: 14px; margin-top: 2px;">Secure, transparent payment portal for citizen self-service</p>
                </div>
                <div class="secure-badge">🔒 SSL Secured Connection</div>
            </div>

            <div class="revenue-layout">
                
                <div class="form-card">
                    <h2 style="font-size: 20px; margin-bottom: 20px;">E-Payment Form</h2>
                    <form onsubmit="return false;">
                        
                        <div class="form-group">
                            <label for="service">Select Revenue Service / Permit</label>
                            <select id="service">
                                <option value="parking">Daily Seasonal Commercial Parking</option>
                                <option value="sbp">Single Business Permit (Retail/MSME)</option>
                                <option value="cess">Agricultural Cess Fee (Logistics)</option>
                                <option value="rates">Land Rates & Property Assessment</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="id-no">National ID / Business Registration Number</label>
                            <input type="text" id="id-no" placeholder="e.g., 12345678 or CPR/2026/XYZ">
                        </div>

                        <div class="form-group">
                            <label for="amount">Amount due (KES)</label>
                            <input type="text" id="amount" value="3,500" disabled style="font-weight: 700; background-color: #f1f5f9;">
                        </div>

                        <div class="form-group">
                            <label>Preferred Payment Mode</label>
                            <div class="payment-methods">
                                <div class="method-option selected">📱 M-PESA</div>
                                <div class="method-option">💳 Credit/Debit Card</div>
                                <div class="method-option">🏦 Agent Bank</div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="phone">M-PESA Phone Number</label>
                            <input type="tel" id="phone" placeholder="e.g., 0712345678">
                        </div>

                        <button class="pay-btn">Initiate Secure Payment</button>
                    </form>
                </div>

                <div class="summary-card">
                    <h2 style="font-size: 18px; margin-bottom: 15px;">Fee Breakdown</h2>
                    
                    <div class="summary-row">
                        <span style="color: #64748b;">Base Permit Fee</span>
                        <span>KES 3,350.00</span>
                    </div>
                    <div class="summary-row">
                        <span style="color: #64748b;">Regulatory Audit Fee</span>
                        <span>KES 150.00</span>
                    </div>
                    <div class="summary-row">
                        <span style="color: #64748b;">Convenience Charge</span>
                        <span>KES 0.00</span>
                    </div>

                    <div class="summary-row total-row">
                        <span>Total Due</span>
                        <span style="color: var(--teal);">KES 3,500.00</span>
                    </div>

                    <p style="font-size: 12px; color: #64748b; margin-top: 20px; line-height: 1.4; text-align: center;">
                        Upon clicking pay, an STK push notification will be sent directly to your mobile phone to complete the automated transaction safely.
                    </p>
                </div>

            </div>
        </main>
    </div>

</body>
</html>
